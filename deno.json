{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --allow-ffi --unstable-ffi --watch main.ts",
    "compile": "deno compile --allow-net --allow-read --allow-env --allow-ffi --include src/native/ main.ts",
    "test": "deno test --allow-read --allow-env"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "jsr:@hono/hono/jsx"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.23",
    "@starfederation/datastar-sdk": "npm:@starfederation/datastar-sdk@^1",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@surrealdb/surrealdb": "jsr:@surrealdb/surrealdb@^1.3.2",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.1.1"
  }
}
