{
  "version": "0.2.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write=./data --allow-sys --allow-env --allow-ffi --unstable-ffi --unstable-kv --watch main.ts",
    "generate-manifest": "deno run --allow-read --allow-write tools/generate-manifest.ts",
    "compile": "deno task generate-manifest && deno compile --allow-net --allow-read --allow-write=./data --allow-sys --allow-env --allow-ffi --unstable-kv main.ts",
    "test": "deno test --allow-read --allow-write --allow-sys --allow-env --unstable-kv"
  },
  "fmt": {
    "exclude": ["BlennyMascot-TS.svg"]
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "jsr:@hono/hono/jsx"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.23",
    "@starfederation/datastar-sdk": "npm:@starfederation/datastar-sdk@^1",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/html": "jsr:@std/html@^1.0.7",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@surrealdb/surrealdb": "npm:surrealdb@^2",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.1.1",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.4.1",
    "@kitsonk/kv-toolbox": "jsr:@kitsonk/kv-toolbox@^0.28.1",
    "@blenny/types": "./src/types.ts",
    "@blenny/core/": "./src/core/",
    "@blenny/lib/": "./src/lib/",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@opentelemetry/sdk-trace-base": "npm:@opentelemetry/sdk-trace-base@^1.30.0"
  }
}
